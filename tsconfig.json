{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "*.tsx",
    "*.ts",
    "pages/**/*",
    "components/**/*",
    "contexts/**/*",
    "hooks/**/*",
    "types/**/*",
    "utils/**/*",
    "src/app/**/*",
    "src/shared/lib/**/*",
    "src/shared/types/hooks.ts",
    "src/styles/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "downloader"
  ]
}